{
  "uid": "techx-slo",
  "title": "TechX SLO Baseline",
  "tags": ["slo", "techx"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "templating": { "list": [] },
  "annotations": { "list": [] },
  "panels": [
    {
      "type": "row",
      "title": "SLO compliance (trên khoảng thời gian đang chọn)",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false
    },
    {
      "type": "stat",
      "title": "Browse non-5xx  (SLO ≥ 99.5%)",
      "datasource": { "type": "prometheus", "uid": "webstore-metrics" },
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "decimals": 3,
          "min": 95,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 99.5 }
            ]
          }
        }
      },
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "webstore-metrics" },
          "expr": "100 * sum(increase(traces_span_metrics_calls_total{service_name=\"frontend\",status_code!=\"STATUS_CODE_ERROR\"}[$__range])) / sum(increase(traces_span_metrics_calls_total{service_name=\"frontend\"}[$__range]))"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Storefront p95 latency  (SLO < 1s)",
      "datasource": { "type": "prometheus", "uid": "webstore-metrics" },
      "gridPos": { "h": 6, "w": 6, "x": 6, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "decimals": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1000 }
            ]
          }
        }
      },
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "webstore-metrics" },
          "expr": "histogram_quantile(0.95, sum by (le) (increase(traces_span_metrics_duration_milliseconds_bucket{service_name=\"frontend-proxy\"}[$__range])))"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Cart success  (SLO ≥ 99.5%)",
      "datasource": { "type": "prometheus", "uid": "webstore-metrics" },
      "gridPos": { "h": 6, "w": 6, "x": 12, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "decimals": 3,
          "min": 95,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 99.5 }
            ]
          }
        }
      },
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "webstore-metrics" },
          "expr": "100 * sum(increase(traces_span_metrics_calls_total{service_name=\"cart\",status_code!=\"STATUS_CODE_ERROR\"}[$__range])) / sum(increase(traces_span_metrics_calls_total{service_name=\"cart\"}[$__range]))"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Checkout success  (SLO ≥ 99.0%)",
      "datasource": { "type": "prometheus", "uid": "webstore-metrics" },
      "gridPos": { "h": 6, "w": 6, "x": 18, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "decimals": 3,
          "min": 95,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 99.0 }
            ]
          }
        }
      },
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "webstore-metrics" },
          "expr": "100 * sum(increase(traces_span_metrics_calls_total{service_name=\"checkout\",status_code!=\"STATUS_CODE_ERROR\"}[$__range])) / sum(increase(traces_span_metrics_calls_total{service_name=\"checkout\"}[$__range]))"
        }
      ]
    },
    {
      "type": "row",
      "title": "Xu hướng theo thời gian",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 7 },
      "collapsed": false
    },
    {
      "type": "timeseries",
      "title": "Success rate theo luồng (%)",
      "datasource": { "type": "prometheus", "uid": "webstore-metrics" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 95,
          "max": 100,
          "custom": { "drawStyle": "line", "fillOpacity": 5, "spanNulls": true },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 99.0 }
            ]
          }
        }
      },
      "options": { "legend": { "displayMode": "table", "calcs": ["min", "mean"] } },
      "targets": [
        {
          "refId": "browse",
          "legendFormat": "browse (frontend)",
          "datasource": { "type": "prometheus", "uid": "webstore-metrics" },
          "expr": "100 * sum(rate(traces_span_metrics_calls_total{service_name=\"frontend\",status_code!=\"STATUS_CODE_ERROR\"}[$__rate_interval])) / sum(rate(traces_span_metrics_calls_total{service_name=\"frontend\"}[$__rate_interval]))"
        },
        {
          "refId": "cart",
          "legendFormat": "cart",
          "datasource": { "type": "prometheus", "uid": "webstore-metrics" },
          "expr": "100 * sum(rate(traces_span_metrics_calls_total{service_name=\"cart\",status_code!=\"STATUS_CODE_ERROR\"}[$__rate_interval])) / sum(rate(traces_span_metrics_calls_total{service_name=\"cart\"}[$__rate_interval]))"
        },
        {
          "refId": "checkout",
          "legendFormat": "checkout",
          "datasource": { "type": "prometheus", "uid": "webstore-metrics" },
          "expr": "100 * sum(rate(traces_span_metrics_calls_total{service_name=\"checkout\",status_code!=\"STATUS_CODE_ERROR\"}[$__rate_interval])) / sum(rate(traces_span_metrics_calls_total{service_name=\"checkout\"}[$__rate_interval]))"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Storefront latency p95 (ms) — ngưỡng 1000ms",
      "datasource": { "type": "prometheus", "uid": "webstore-metrics" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 5,
            "thresholdsStyle": { "mode": "line" }
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1000 }
            ]
          }
        }
      },
      "options": { "legend": { "displayMode": "table", "calcs": ["max", "mean"] } },
      "targets": [
        {
          "refId": "p95",
          "legendFormat": "p95 frontend-proxy",
          "datasource": { "type": "prometheus", "uid": "webstore-metrics" },
          "expr": "histogram_quantile(0.95, sum by (le) (rate(traces_span_metrics_duration_milliseconds_bucket{service_name=\"frontend-proxy\"}[$__rate_interval])))"
        },
        {
          "refId": "p99",
          "legendFormat": "p99 frontend-proxy",
          "datasource": { "type": "prometheus", "uid": "webstore-metrics" },
          "expr": "histogram_quantile(0.99, sum by (le) (rate(traces_span_metrics_duration_milliseconds_bucket{service_name=\"frontend-proxy\"}[$__rate_interval])))"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Throughput (req/s tại edge) — bối cảnh load test",
      "datasource": { "type": "prometheus", "uid": "webstore-metrics" },
      "gridPos": { "h": 7, "w": 24, "x": 0, "y": 16 },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "drawStyle": "line", "fillOpacity": 10 }
        }
      },
      "options": { "legend": { "displayMode": "list", "calcs": ["max"] } },
      "targets": [
        {
          "refId": "rps",
          "legendFormat": "{{service_name}}",
          "datasource": { "type": "prometheus", "uid": "webstore-metrics" },
          "expr": "sum by (service_name) (rate(traces_span_metrics_calls_total{service_name=~\"frontend-proxy|frontend|cart|checkout\"}[$__rate_interval]))"
        }
      ]
    }
  ]
}
