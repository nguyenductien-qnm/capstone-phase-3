# Copy file này thành terraform.tfvars và điền các giá trị thực tế.
# KHÔNG commit terraform.tfvars vào Git — chỉ commit file .example này.

# ============================================================
# Cấu hình chung
# ============================================================
aws_region   = "us-east-1"
project_name = "<PROJECT_NAME>"       # vd: ecommerce
environment  = "dev"                  # dev | staging | prod

# ============================================================
# Cấu hình VPC & Subnet
# ============================================================
vpc_cidr = "10.0.0.0/16"

public_subnets = {
  "pub-1" = { cidr_block = "10.0.1.0/24", availability_zone = "us-east-1a" }
  "pub-2" = { cidr_block = "10.0.2.0/24", availability_zone = "us-east-1b" }
  "pub-3" = { cidr_block = "10.0.3.0/24", availability_zone = "us-east-1c" }
}

private_app_subnets = {
  "app-1" = { cidr_block = "10.0.11.0/24", availability_zone = "us-east-1a" }
  "app-2" = { cidr_block = "10.0.12.0/24", availability_zone = "us-east-1b" }
  "app-3" = { cidr_block = "10.0.13.0/24", availability_zone = "us-east-1c" }
}

private_data_subnets = {
  "data-1" = { cidr_block = "10.0.21.0/24", availability_zone = "us-east-1a" }
  "data-2" = { cidr_block = "10.0.22.0/24", availability_zone = "us-east-1b" }
}

private_mq_subnets = {
  "mq-1" = { cidr_block = "10.0.31.0/24", availability_zone = "us-east-1a" }
  "mq-2" = { cidr_block = "10.0.32.0/24", availability_zone = "us-east-1b" }
}

enable_nat_gateway = true
single_nat_gateway = true   # false để tạo NAT GW ở mỗi AZ (production)

public_subnet_tags = {
  "kubernetes.io/role/elb"                         = "1"
  "kubernetes.io/cluster/<PROJECT_NAME>-dev-eks"   = "shared"
}

private_subnet_tags = {
  "kubernetes.io/cluster/<PROJECT_NAME>-dev-eks"   = "shared"
}

# ============================================================
# Cấu hình EKS
# ============================================================
eks_cluster_version     = "1.36"
eks_node_instance_types = ["t3.medium"]
eks_node_capacity_type  = "ON_DEMAND"   # hoặc SPOT

eks_node_scaling = {
  min_size     = 2
  max_size     = 3
  desired_size = 2
}

# Dedicated observability MNG: fixed at one non-burstable node in us-east-1b.
eks_ops_node_subnet_key     = "app-2"
eks_ops_node_instance_types = ["m6a.large"]
eks_ops_node_disk_size_gib  = 30

# Bật public access cho phép kết nối từ ngoài VPC qua SSO.
# Production: đặt false và dùng VPN/bastion.
eks_endpoint_public_access = true
eks_public_access_cidrs    = ["0.0.0.0/0"]   # Giới hạn lại IP thực tế nếu cần

eks_control_plane_log_retention_days = 7

# Dùng IAM Role ARN (từ IAM Console), không dùng STS assumed-role ARN
eks_access_entries = {
  platform_admin = {
    principal_arn      = "arn:aws:iam::<ACCOUNT_ID>:role/aws-reserved/sso.amazonaws.com/<REGION>/AWSReservedSSO_<PERMISSION_SET>_<SUFFIX>"
    access_policy_name = "AmazonEKSClusterAdminPolicy"
    access_scope_type  = "cluster"
  }

  # Ví dụ: cấp quyền namespace cho team AIO
  # aio = {
  #   principal_arn      = "arn:aws:iam::<ACCOUNT_ID>:role/aws-reserved/sso.amazonaws.com/<REGION>/AWSReservedSSO_<AIO_PERMISSION_SET>_<SUFFIX>"
  #   access_policy_name = "AmazonEKSAdminPolicy"
  #   access_scope_type  = "namespace"
  #   namespaces         = ["techx-tf1"]
  # }
}

# ============================================================
# Cấu hình RDS PostgreSQL
# ============================================================
db_name                = "<DB_NAME>"      # vd: ecommerce_db
db_username            = "<DB_USERNAME>"  # vd: db_admin
rds_instance_class     = "db.t4g.micro"
rds_allocated_storage  = 20
enable_read_replica    = true
replica_instance_class = "db.t4g.micro"
enable_rds_proxy       = true
rds_multi_az           = true

# ============================================================
# Cấu hình ElastiCache Valkey
# ============================================================
valkey_node_type          = "cache.t4g.micro"
valkey_num_cache_clusters = 2

# ============================================================
# Cấu hình ECR
# ============================================================
ecr_repositories = ["<REPO_NAME>"]   # vd: ["techx-corp"]

# ============================================================
# Cấu hình CloudFront & Custom Domain
# ============================================================

# CloudFront origin = origin-<subdomain>, record do external-dns tự tạo trỏ về ALB
# của Ingress frontend-proxy. Không cần điền DNS của LB thủ công.
route53_zone_id = "<ROUTE53_ZONE_ID>"   # vd: Z0648007EUNFYEFE8XC4

subdomain           = "<SUBDOMAIN>"           # vd: ecommerce.yourdomain.com
acm_certificate_arn = "arn:aws:acm:us-east-1:<ACCOUNT_ID>:certificate/<CERT_ID>"

enable_cloudfront = true

# ============================================================
# Audit trail (CDO-46/CDO-105/CDO-106)
# ============================================================
eks_enabled_cluster_log_types        = ["api", "audit", "authenticator"]
eks_enable_control_plane_log_kms     = true
cloudtrail_enable_kms_encryption     = true
cloudtrail_enable_cloudwatch_logs    = true
cloudtrail_cloudwatch_log_retention_days = 90
cloudtrail_s3_transition_days        = 90
cloudtrail_s3_transition_storage_class = "GLACIER_IR"
cloudtrail_s3_retention_days         = 2555
cloudtrail_enable_object_lock        = false
cloudtrail_object_lock_retention_days = 30
audit_administrator_principals       = []
audit_break_glass_principals          = []
audit_operator_role_names             = []

# ============================================================
# MANDATE-11 audit detection (CDO-05)
# ============================================================
# Giữ false để plan/apply hiện tại không tạo tài nguyên. Trước khi bật, tạo
# webhook trong SSM Parameter Store hoặc Secrets Manager; không ghi URL webhook
# trực tiếp vào tfvars/Git.
audit_detection_enabled                = false
audit_pipeline_health_email_endpoints  = []
audit_slack_webhook_parameter_arn      = null
audit_slack_webhook_kms_key_arn        = null
audit_detection_break_glass_role_arns  = []
