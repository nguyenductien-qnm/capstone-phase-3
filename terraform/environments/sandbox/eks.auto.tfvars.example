# Copy the relevant values into your private *.tfvars file. Do not commit real
# account IDs, SSO role suffixes or workstation/VPN CIDRs.

eks_cluster_version    = "<REVIEWED_EKS_VERSION>"
eks_node_instance_types = ["t3.large"]

# Keep false when kubectl/Argo CD reaches the private endpoint through VPN,
# bastion or a runner inside the VPC. For local SSO access, enable it only with
# the operator's current public IP or corporate VPN CIDR.
eks_endpoint_public_access = true
eks_public_access_cidrs     = ["203.0.113.10/32"]

eks_node_capacity_type = "ON_DEMAND"
eks_node_scaling = {
  min_size     = 2
  max_size     = 6
  desired_size = 2
}

eks_access_entries = {
  sso_platform_admin = {
    # Use the IAM role ARN shown in IAM, not the arn:aws:sts::... assumed-role
    # ARN returned for the current SSO session.
    principal_arn      = "arn:aws:iam::<ACCOUNT_ID>:role/aws-reserved/sso.amazonaws.com/<IDENTITY_CENTER_REGION>/AWSReservedSSO_<PERMISSION_SET>_<SUFFIX>"
    access_policy_name = "AmazonEKSClusterAdminPolicy"
    access_scope_type  = "cluster"
  }

  # Example for a later automation role. Prefer namespace scope and do not
  # grant cluster admin merely because the role authenticates with OIDC.
  # github_gitops = {
  #   principal_arn      = "arn:aws:iam::<ACCOUNT_ID>:role/techx-github-gitops"
  #   access_policy_name = "AmazonEKSEditPolicy"
  #   access_scope_type  = "namespace"
  #   namespaces         = ["techx-tf1"]
  # }
}
