terraform {
  required_version = ">= 1.5.0"

  required_providers {
    aws = {
      source  = "hashicorp/aws"
      version = "~> 5.0"
    }
  }

}

provider "aws" {
  region              = var.aws_region
  allowed_account_ids = [var.aws_account_id]

  default_tags {
    tags = {
      Project     = "capstone-phase-3"
      Environment = "develop"
      ManagedBy   = "Terraform"
      Purpose     = "DevelopBootstrap"
    }
  }
}
